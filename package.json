{
  "name": "cortex-mcp",
  "version": "0.2.0",
  "description": "Universal AI memory, context, and automation server using the Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cortex-mcp": "dist/index.js",
    "cortex-mcp-http": "dist/http.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "agents": "^0.7.6",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "hono": "^4.12.8",
    "nanoid": "^5.1.5",
    "node-notifier": "^10.0.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260316.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.73.0"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "memory",
    "knowledge-base",
    "context",
    "claude",
    "gpt",
    "llm"
  ],
  "author": "Resolut1onEDL",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Resolut1onEDL/cortex-mcp.git"
  },
  "homepage": "https://github.com/Resolut1onEDL/cortex-mcp#readme",
  "bugs": {
    "url": "https://github.com/Resolut1onEDL/cortex-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
