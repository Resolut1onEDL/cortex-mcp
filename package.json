{
  "name": "cortex-mcp",
  "version": "0.1.0",
  "description": "Universal AI memory, context, and automation server using the Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cortex-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "nanoid": "^5.1.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "memory",
    "knowledge-base",
    "context",
    "claude",
    "gpt",
    "llm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
